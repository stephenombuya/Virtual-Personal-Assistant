# ─────────────────────────────────────────────────────────────
# Virtual Personal Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────────
APP_NAME=VoiceAssistant
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
# LOG_FILE=logs/assistant.log   # Comment out to log to stdout only
ASSISTANT_NAME=Assistant
WAKE_WORD=hey assistant

# ── Weather (OpenWeatherMap) ───────────────────────────────────
# Get a free key at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here
WEATHER_DEFAULT_UNITS=metric        # metric | imperial | standard
# WEATHER_DEFAULT_CITY=Nairobi     # Optional: used when no city is spoken

# ── News (NewsAPI) ─────────────────────────────────────────────
# Get a free key at: https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here
NEWS_COUNTRY=us                     # ISO 3166-1 alpha-2 country code
NEWS_PAGE_SIZE=5                    # Number of headlines to read (1–20)

# ── Speech Recognition ─────────────────────────────────────────
SPEECH_RATE=175                     # Words per minute (50–400)
SPEECH_VOLUME=0.9                   # Volume level (0.0–1.0)
SPEECH_VOICE_GENDER=female          # female | male
SPEECH_ENERGY_THRESHOLD=300         # Mic sensitivity (100–4000)
SPEECH_PAUSE_THRESHOLD=0.8          # Silence before end of phrase (seconds)
SPEECH_RECOGNITION_TIMEOUT=10       # Max seconds to wait for speech
SPEECH_PHRASE_TIME_LIMIT=15         # Max seconds for a single phrase

# ── Database ───────────────────────────────────────────────────
DB_PATH=data/assistant.db           # Relative path to SQLite database file
DB_ECHO=false                       # Set true to log all SQL queries (debug)
